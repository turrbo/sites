# Google Sheets Configuration
GOOGLE_SHEET_ID=your-spreadsheet-id-here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----"

# Optional: customize sheet tab names (defaults shown)
SHEETS_LISTINGS_TAB=Listings
SHEETS_CATEGORIES_TAB=Categories
SHEETS_SEO_PAGES_TAB=SEO Pages

# Site URL (set to your Vercel domain)
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app

# On-demand Revalidation Secret
REVALIDATION_SECRET=your-secret-here
